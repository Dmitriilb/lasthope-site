# Last Hope Bar — Environment Variables
# Copy this file to .env and fill in your values

# Site URL
VITE_SITE_URL=https://lasthope.bar

# Admin panel password (used in admin.html and events.html)
VITE_ADMIN_PASSWORD=lasthope2025

# Google Maps embed key (optional)
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Google Maps Place ID
VITE_MAPS_PLACE_ID=ChIJxxxxxxxxxxxxxxxxxx
